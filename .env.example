# Core app
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-32-byte-secret
# Local dev (docker-compose Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/friends_guest_room?schema=public"

# Admin bootstrap (required for seed)
ADMIN_EMAIL_1=you@example.com
ADMIN_EMAIL_2=spouse@example.com
ADMIN_EMAILS=you@example.com,spouse@example.com

# Email / magic links (optional in local dev)
# If missing, app logs email payloads to console instead of sending.
RESEND_API_KEY=
EMAIL_FROM=The Grow Room <growroom@example.com>

# Optional Google OAuth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Google Calendar integration
GOOGLE_REFRESH_TOKEN=
GOOGLE_BLACKOUT_CALENDAR_ID=
GOOGLE_WRITE_ENABLED=false
GOOGLE_BOOKING_CALENDAR_ID=

# Security
ENCRYPTION_KEY=replace-with-long-random-string
CRON_SECRET=replace-with-random-secret

# Optional fallback static door codes
PROPERTY_DOOR_CODE=
GUEST_ROOM_DOOR_CODE=

# Optional seed defaults
DEFAULT_WIFI_NAME=Guest Wi-Fi
DEFAULT_WIFI_PASSWORD=
DEFAULT_VENMO_HANDLE=@your-venmo
