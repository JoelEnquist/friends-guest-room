generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GUEST
}

enum BookingStatus {
  NEEDS_APPROVAL
  APPROVED
  DENIED
  CANCELLED
}

enum CleaningPlan {
  SELF_CLEAN
  PAY_VENMO_OR_CASH
}

enum BookingSource {
  GUEST_REQUEST
  ADMIN_MANUAL
}

enum BlackoutSource {
  LOCAL
  GOOGLE
}

enum InviteRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum SuggestionCategory {
  SUPPLIES_RESTOCK
  LAYOUT_COMFORT
  INSTRUCTIONS_GUIDEBOOK
  CLEANING_TURNOVER
  SAFETY_SECURITY
  OTHER
}

enum SuggestionOwnerEffort {
  ZERO_MIN
  LT_5_MIN
  MIN_5_TO_15
  MIN_15_TO_60
  GT_60_MIN
}

enum SuggestionStatus {
  NEW
  REVIEWING
  ACCEPTED
  DONE
  DECLINED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(GUEST)
  allowed       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[] @relation("GuestBookings")
  suggestions   Suggestion[]
  inviteRequests InviteRequest[] @relation("InviteRequestReviewer")

  @@index([allowed])
}

model Booking {
  id             String        @id @default(cuid())
  guestEmail     String
  guestName      String
  guestUserId    String?
  guestUser      User?         @relation("GuestBookings", fields: [guestUserId], references: [id], onDelete: SetNull)
  startDate      DateTime
  endDate        DateTime
  status         BookingStatus @default(NEEDS_APPROVAL)
  cleaningPlan   CleaningPlan
  note           String?
  phone          String?
  adminMessage   String?
  source         BookingSource @default(GUEST_REQUEST)
  googleEventId  String?
  reminderSentAt DateTime?
  arrivalEmailSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  suggestions    Suggestion[]   @relation("SuggestionRelatedBooking")

  @@index([guestEmail])
  @@index([status])
  @@index([startDate, endDate])
}

model Blackout {
  id        String         @id @default(cuid())
  title     String?
  startDate DateTime
  endDate   DateTime
  source    BlackoutSource @default(LOCAL)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([startDate, endDate])
}

model Settings {
  id                    Int      @id @default(1)
  propertyDoorCodeEnc   String?
  guestRoomDoorCodeEnc  String?
  lastDoorCodeRotationAt DateTime?
  wifiName              String?
  wifiPassword          String?
  arrivalInstructions   String?
  guidebookText         String?
  nearbyRecommendations String?
  polycamLink           String?
  photosJson            String?
  venmoHandle           String?
  paymentInstructions   String?
  checkoutChecklist     String?
  updatedAt             DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String?
  actionType String
  payload    String?
  timestamp  DateTime @default(now())

  @@index([timestamp])
  @@index([actionType])
}

model InviteRequest {
  id                String             @id @default(cuid())
  fullName          String
  email             String
  socialProfileUrl  String
  mutualContact     String
  tripPurpose       String
  requestedStartDate DateTime
  requestedEndDate   DateTime
  status            InviteRequestStatus @default(PENDING)
  reviewedAt        DateTime?
  reviewedByUserId  String?
  reviewedBy        User?               @relation("InviteRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model Suggestion {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedBookingId   String?
  relatedBooking     Booking?             @relation("SuggestionRelatedBooking", fields: [relatedBookingId], references: [id], onDelete: SetNull)
  title              String
  idea               String
  category           SuggestionCategory
  sustainabilityPlan String
  ownerEffort        SuggestionOwnerEffort
  estimatedCost      String?
  productUrl         String?
  status             SuggestionStatus     @default(NEW)
  adminNotes         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([userId, createdAt])
  @@index([status, category])
  @@index([category])
  @@index([relatedBookingId])
  @@index([createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
